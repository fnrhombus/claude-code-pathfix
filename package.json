{
  "name": "claude-code-pathfix",
  "version": "2.0.2",
  "description": "Claude Code hook that transparently converts Windows paths to POSIX in Bash commands — eliminating retry loops and saving tokens",
  "main": "dist/index.js",
  "bin": {
    "claude-code-pathfix": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "claude-code",
    "claude",
    "hook",
    "windows",
    "path",
    "posix",
    "git-bash",
    "msys2",
    "wsl",
    "token-saving",
    "developer-tools",
    "ai-coding",
    "mcp"
  ],
  "author": "fnrhombus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fnrhombus/claude-code-pathfix.git"
  },
  "bugs": {
    "url": "https://github.com/fnrhombus/claude-code-pathfix/issues"
  },
  "homepage": "https://github.com/fnrhombus/claude-code-pathfix#readme",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@fnrhombus/claude-code-hooks": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
